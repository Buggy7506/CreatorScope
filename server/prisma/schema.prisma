generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  YOUTUBE
  TIKTOK
  INSTAGRAM
  GOOGLE
  GA4
  MICROSOFT
  APPLE
}

enum AnalyticsEventType {
  VIEW
  WATCH_TIME
  IMPRESSION
  CLICK_THROUGH
  LIKE
  COMMENT
  SHARE
  SAVE
  SUBSCRIBER_GAIN
  FOLLOWER_GAIN
  REVENUE
  TRAFFIC_SOURCE
  RETENTION_SAMPLE
  ANOMALY
}

enum AudienceSegmentType {
  NEW_VIEWER
  RETURNING_VIEWER
  LOYAL_SUBSCRIBER
  CASUAL_SUBSCRIBER
  PSYCHOGRAPHIC_COHORT
}

enum RevenueSourceType {
  ADSENSE
  SPONSORSHIP
  MEMBERSHIP
  SUPER_CHAT
  SUPER_STICKER
  AFFILIATE
  COMMERCE
}

enum PredictionType {
  VIEW_FORECAST
  REVENUE_FORECAST
  RETENTION_PREDICTION
  VIRALITY_PREDICTION
  TREND_FORECAST
  AUDIENCE_SEGMENTATION
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
}

model User {
  id String @id @default(cuid())

  email     String  @unique
  password  String
  name      String
  timezone  String  @default("UTC")
  avatarUrl String?

  workspaces         WorkspaceMember[]
  connectedAccounts  ConnectedAccount[]
  youtubeSnapshots   YoutubeSnapshot[]
  ga4Snapshots       Ga4Snapshot[]
  subscriptions      Subscription[]
  analyticsCaches    AnalyticsCache[]
  analyticsSnapshots AnalyticsSnapshot[]
  contentAssets      ContentAsset[]
  analyticsEvents    AnalyticsEvent[]
  revenueEvents      RevenueEvent[]
  audienceCohorts    AudienceCohort[]
  aiPredictions      AiPrediction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConnectedAccount {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform       Platform
  platformUserId String?
  username       String?
  displayName    String?
  channelId      String?
  profileUrl     String?
  scopes         String[] @default([])

  accessToken    String?
  refreshToken   String?
  tokenExpiry    DateTime?
  expiresAt      DateTime?
  connectedAt    DateTime  @default(now())
  disconnectedAt DateTime?

  metadata Json?

  youtubeSnapshots YoutubeSnapshot[]
  ga4Snapshots     Ga4Snapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform, platformUserId])
  @@index([userId, platform])
  @@index([platform, channelId])
  @@index([tokenExpiry])
}

model YoutubeSnapshot {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  connectedAccountId String
  connectedAccount   ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  channelId String
  date      DateTime @db.Date

  views                   BigInt  @default(0)
  likes                   BigInt  @default(0)
  dislikes                BigInt  @default(0)
  comments                BigInt  @default(0)
  shares                  BigInt  @default(0)
  subscribers             BigInt  @default(0)
  subscribersGained       BigInt  @default(0)
  subscribersLost         BigInt  @default(0)
  averageViewDuration     Decimal @default(0) @db.Decimal(18, 6)
  estimatedMinutesWatched Decimal @default(0) @db.Decimal(18, 6)
  revenue                 Decimal @default(0) @db.Decimal(18, 6)
  estimatedRevenue        Decimal @default(0) @db.Decimal(18, 6)
  estimatedAdRevenue      Decimal @default(0) @db.Decimal(18, 6)
  currency                String  @default("USD")

  rawDemographics Json?
  rawTrafficSources Json?
  rawPayload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([connectedAccountId, channelId, date])
  @@index([userId, date])
  @@index([channelId, date])
  @@index([views])
  @@index([subscribers])
  @@index([revenue])
}

model Ga4Snapshot {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  connectedAccountId String
  connectedAccount   ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  propertyId String
  date       DateTime @db.Date

  activeUsers            BigInt  @default(0)
  newUsers               BigInt  @default(0)
  sessions               BigInt  @default(0)
  pageViews              BigInt  @default(0)
  screenPageViews        BigInt  @default(0)
  averageSessionDuration Decimal @default(0) @db.Decimal(18, 6)
  engagementRate         Decimal @default(0) @db.Decimal(8, 6)
  conversions            Decimal @default(0) @db.Decimal(18, 6)
  purchaseRevenue        Decimal @default(0) @db.Decimal(18, 6)
  currency               String  @default("USD")

  campaignConversions Json?
  attribution         Json?
  rawPayload          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([connectedAccountId, propertyId, date])
  @@index([userId, date])
  @@index([propertyId, date])
  @@index([activeUsers])
  @@index([sessions])
  @@index([pageViews])
}

model Subscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier   SubscriptionTier   @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  stripeCustomerId     String?
  stripeSubscriptionId String? @unique
  stripePriceId        String?
  stripeProductId      String?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?
  trialEndsAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([stripeCustomerId])
}

model AnalyticsCache {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform   Platform?
  cacheKey   String
  rangeStart DateTime?
  rangeEnd   DateTime?
  expiresAt  DateTime

  totalViews         BigInt   @default(0)
  totalFollowers     BigInt   @default(0)
  totalEarningsCents BigInt   @default(0)
  engagementRate     Decimal? @db.Decimal(8, 4)
  growthRate         Decimal? @db.Decimal(8, 4)

  payload Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform, cacheKey])
  @@index([userId, expiresAt])
}

model AnalyticsSnapshot {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform Platform

  subscribers Int
  totalViews  Int
  totalVideos Int

  snapshotDate DateTime @default(now())

  createdAt DateTime @default(now())
}


model Workspace {
  id String @id @default(cuid())

  name        String
  slug        String @unique
  ownerUserId String
  timezone    String @default("UTC")
  metadata    Json?

  members          WorkspaceMember[]
  contentAssets    ContentAsset[]
  analyticsEvents  AnalyticsEvent[]
  revenueEvents    RevenueEvent[]
  audienceCohorts  AudienceCohort[]
  aiPredictions    AiPrediction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkspaceMember {
  id String @id @default(cuid())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      String   @default("creator")
  scopes    String[] @default([])
  invitedAt DateTime @default(now())
  joinedAt  DateTime?

  @@unique([workspaceId, userId])
  @@index([userId, role])
}

model ContentAsset {
  id String @id @default(cuid())

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform          Platform
  platformContentId String
  canonicalGroupId  String?
  title             String?
  description       String?
  contentType       String
  publishedAt       DateTime?
  durationSeconds   Int?
  metadata          Json?

  analyticsEvents AnalyticsEvent[]
  revenueEvents   RevenueEvent[]
  aiPredictions   AiPrediction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform, platformContentId])
  @@index([workspaceId, platform, publishedAt])
  @@index([canonicalGroupId])
}

model AnalyticsEvent {
  id String @id @default(cuid())

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contentAssetId String?
  contentAsset   ContentAsset? @relation(fields: [contentAssetId], references: [id], onDelete: SetNull)

  platform      Platform
  eventType     AnalyticsEventType
  metricName    String
  metricValue   Decimal @db.Decimal(18, 6)
  observedAt    DateTime
  source         String?
  countryCode    String?
  deviceType     String?
  trafficSource  String?
  cohortKey      String?
  correlationKey String?
  metadata       Json?

  createdAt DateTime @default(now())

  @@index([workspaceId, platform, observedAt])
  @@index([userId, eventType, observedAt])
  @@index([contentAssetId, metricName, observedAt])
  @@index([correlationKey])
}

model RevenueEvent {
  id String @id @default(cuid())

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contentAssetId String?
  contentAsset   ContentAsset? @relation(fields: [contentAssetId], references: [id], onDelete: SetNull)

  platform      Platform?
  sourceType    RevenueSourceType
  amountCents   BigInt
  currency      String   @default("USD")
  rpm           Decimal? @db.Decimal(12, 4)
  cpm           Decimal? @db.Decimal(12, 4)
  countryCode   String?
  deviceType    String?
  category      String?
  occurredAt    DateTime
  attribution   Json?
  metadata      Json?

  createdAt DateTime @default(now())

  @@index([workspaceId, sourceType, occurredAt])
  @@index([userId, platform, occurredAt])
  @@index([contentAssetId, occurredAt])
}

model AudienceCohort {
  id String @id @default(cuid())

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  segmentType AudienceSegmentType
  name        String
  platform    Platform?
  size        Int?
  affinity    Json?
  heatmap     Json?
  metadata    Json?
  measuredAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, segmentType, measuredAt])
  @@index([userId, platform, measuredAt])
}

model AiPrediction {
  id String @id @default(cuid())

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contentAssetId String?
  contentAsset   ContentAsset? @relation(fields: [contentAssetId], references: [id], onDelete: SetNull)

  predictionType PredictionType
  modelName      String
  modelVersion   String
  score          Decimal? @db.Decimal(12, 6)
  forecast       Json
  features       Json?
  explanations   Json?
  validFrom      DateTime @default(now())
  validUntil     DateTime?

  createdAt DateTime @default(now())

  @@index([workspaceId, predictionType, validFrom])
  @@index([userId, predictionType, validFrom])
  @@index([contentAssetId, predictionType])
}
